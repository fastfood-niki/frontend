---
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';
import MobileNavDrawer from '../components/layout/MobileNavDrawer.astro';
import { restaurant as defaultRestaurant, type RestaurantInfo } from '../data/restaurant';

interface Props {
	title?: string;
	description?: string;
	restaurant?: RestaurantInfo;
}

const { title, description, restaurant: restaurantProp } = Astro.props;

const r = restaurantProp ?? defaultRestaurant;
const pageTitle = title ?? `${r.name} · Menyja`;
const metaDescription =
	description ??
	`${r.name} — ${r.tagline}. Menyja e plotë digjitale: picë, hamburger, skarë, sallata, sandwich, mëngjes e më shumë. ${r.deliveryNote}. Porosi: ${r.phone}.`;

const site = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, site);
const ogImageURL = new URL('/og-image.png', site);

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Restaurant',
	name: r.name,
	description: metaDescription,
	telephone: r.phoneHref.replace(/^tel:/i, ''),
	url: canonicalURL.href,
	image: ogImageURL.href,
	servesCuisine: 'Fast food',
	...(r.coordinates
		? {
				geo: {
					'@type': 'GeoCoordinates',
					latitude: r.coordinates.lat,
					longitude: r.coordinates.lng,
				},
			}
		: {}),
};
---

<!doctype html>
<html lang="sq" class="font-sans">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />

		<title>{pageTitle}</title>
		<meta name="description" content={metaDescription} />
		<meta name="theme-color" content="#09090b" />
		<meta name="application-name" content={r.name} />
		<meta name="apple-mobile-web-app-title" content={r.name} />
		<meta name="format-detection" content="telephone=yes" />
		<meta name="robots" content="index, follow" />

		<link rel="canonical" href={canonicalURL.href} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:site_name" content={r.name} />
		<meta property="og:locale" content="sq_AL" />
		<meta property="og:image" content={ogImageURL.href} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={`${r.name} — ${r.tagline}`} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content={ogImageURL.href} />

		<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-dvh bg-zinc-950 text-zinc-100 antialiased">
		<a
			href="#menu"
			class="fixed left-4 top-4 z-[100] -translate-y-[calc(100%+1rem)] rounded-lg bg-amber-400 px-4 py-3 text-sm font-semibold text-zinc-950 shadow-lg transition-transform duration-200 focus:translate-y-0 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-amber-200"
		>
			Shko te menuja
		</a>
		<slot />
		<MobileNavDrawer />
		<Analytics />
	</body>
</html>
