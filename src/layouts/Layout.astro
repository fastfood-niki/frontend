---
import '../styles/global.css';
import MobileNavDrawer from '../components/layout/MobileNavDrawer.astro';
import { restaurant as defaultRestaurant, type RestaurantInfo } from '../data/restaurant';

interface Props {
	title?: string;
	description?: string;
	restaurant?: RestaurantInfo;
}

const {
	title,
	description = 'Fast Food NIKI — menu digjital.',
	restaurant: restaurantProp,
} = Astro.props;

const r = restaurantProp ?? defaultRestaurant;
const pageTitle = title ?? `${r.name} · Menyja`;
---

<!doctype html>
<html lang="sq" class="font-sans">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#09090b" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700&display=swap"
			rel="stylesheet"
		/>
		<title>{pageTitle}</title>
	</head>
	<body class="min-h-dvh bg-zinc-950 text-zinc-100 antialiased">
		<a
			href="#menu"
			class="fixed left-4 top-4 z-[100] -translate-y-[calc(100%+1rem)] rounded-lg bg-amber-400 px-4 py-3 text-sm font-semibold text-zinc-950 shadow-lg transition-transform duration-200 focus:translate-y-0 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-amber-200"
		>
			Shko te menuja
		</a>
		<slot />
		<MobileNavDrawer />
	</body>
</html>
