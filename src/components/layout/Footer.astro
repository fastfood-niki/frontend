---
import Container from '../common/Container.astro';
import { restaurant } from '../../data/restaurant';

const year = new Date().getFullYear();
---

<footer
	class="mt-3 border-t border-amber-950/30 bg-gradient-to-t from-black/40 to-zinc-950 pb-[calc(2rem+env(safe-area-inset-bottom))] pt-14"
>
	<Container>
		<div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
			<div>
				<p class="font-display text-lg font-semibold text-amber-100/95">{restaurant.name}</p>
				<p class="mt-1 text-sm text-zinc-500">{restaurant.tagline}</p>
			</div>
			<a
				href={restaurant.phoneHref}
				class="inline-flex items-center justify-center rounded-full border border-amber-600/30 bg-amber-500/10 px-5 py-2.5 text-sm font-semibold text-amber-300 transition hover:border-amber-500/50 hover:bg-amber-500/15 hover:text-amber-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-400"
			>
				{restaurant.phone}
			</a>
		</div>
		<p class="mt-10 text-center text-xs text-zinc-600">
			© {year}
			{restaurant.name}
		</p>
	</Container>
</footer>
