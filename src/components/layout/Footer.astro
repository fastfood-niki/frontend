---
import Container from '../common/Container.astro';
import { restaurant } from '../../data/restaurant';
import { appleMapsUrl, googleMapsUrl, openStreetMapEmbedUrl } from '../../lib/maps';

const year = new Date().getFullYear();
const coords = restaurant.coordinates;
const embedUrl = coords ? openStreetMapEmbedUrl(coords.lat, coords.lng) : null;
const googleUrl = coords ? googleMapsUrl(coords.lat, coords.lng) : '';
const appleUrl = coords ? appleMapsUrl(coords.lat, coords.lng, restaurant.name) : '';
---

<footer
	class="mt-3 border-t border-red-950/45 bg-gradient-to-t from-black to-zinc-950 pb-[calc(2rem+env(safe-area-inset-bottom))] pt-14"
>
	<Container>
		<div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
			<div>
				<img
					src="/logo-niki-512.png"
					alt={restaurant.name}
					width="512"
					height="249"
					class="mx-auto h-8 w-auto sm:mx-0"
					loading="lazy"
					decoding="async"
				/>
				<p class="mt-1 text-sm text-zinc-400">{restaurant.tagline}</p>
			</div>
			<a
				href={restaurant.phoneHref}
				class="inline-flex items-center justify-center rounded-full border border-red-700/45 bg-red-500/14 px-5 py-2.5 text-sm font-semibold text-yellow-200 transition hover:border-red-500/65 hover:bg-red-500/22 hover:text-yellow-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400"
			>
				{restaurant.phone}
			</a>
		</div>

		{
			coords && embedUrl && (
				<div class="mx-auto mt-12 w-full max-w-2xl">
					<div class="overflow-hidden rounded-xl border border-red-900/45 bg-zinc-900/45 shadow-lg shadow-black/35 ring-1 ring-red-500/[0.12]">
						<div class="aspect-[16/10] w-full md:aspect-[2/1]">
							<iframe
								title={`Harta — ${restaurant.name}`}
								class="h-full w-full border-0"
								src={embedUrl}
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"
							/>
						</div>
					</div>
					<div class="mt-4 flex w-full flex-col gap-3 md:flex-row md:items-center md:justify-between">
						<a
							href={googleUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex min-h-[2.75rem] flex-1 items-center justify-center rounded-full border border-red-700/40 bg-zinc-900/70 px-5 py-2.5 text-sm font-semibold text-yellow-200 transition hover:border-red-500/65 hover:bg-red-500/16 hover:text-yellow-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400 md:flex-none md:min-w-[11rem]"
						>
							Hap në Google Maps
						</a>
						<a
							href={appleUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex min-h-[2.75rem] flex-1 items-center justify-center rounded-full border border-red-700/40 bg-zinc-900/70 px-5 py-2.5 text-sm font-semibold text-yellow-200 transition hover:border-red-500/65 hover:bg-red-500/16 hover:text-yellow-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400 md:flex-none md:min-w-[11rem]"
						>
							Hap në Apple Maps
						</a>
					</div>
				</div>
			)
		}

		<p class="mt-10 text-center text-xs text-zinc-500">
			© {year}
			{restaurant.name}
		</p>
	</Container>
</footer>
