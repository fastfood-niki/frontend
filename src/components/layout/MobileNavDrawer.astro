---
import { mainNavItems } from '../../data/navigation';
import { restaurant } from '../../data/restaurant';

const menuHref = mainNavItems[0]?.href ?? '#menu';
const menuLabel = mainNavItems[0]?.label ?? 'Menyja';
---

<div
	id="mobile-nav-drawer-root"
	class="mobile-nav-drawer-root fixed inset-0 z-[200] max-w-full overflow-x-clip md:hidden"
	aria-hidden="true"
>
	<button
		type="button"
		class="mobile-nav-drawer-backdrop absolute inset-0 z-0 bg-black/82 sm:bg-black/70 sm:backdrop-blur-lg supports-[backdrop-filter]:sm:bg-black/55"
		data-mobile-drawer-backdrop
		aria-label="Mbyll menynë"
	>
	</button>

	<aside
		id="mobile-nav-drawer"
		class="mobile-nav-drawer-panel absolute right-0 top-0 z-10 flex h-full max-h-[100dvh] min-w-0 w-[min(22rem,calc(100%-1rem))] max-w-[min(22rem,calc(100%-1rem))] flex-col border-l border-red-900/55 bg-black pt-[env(safe-area-inset-top)] shadow-2xl shadow-black/75 ring-1 ring-red-500/[0.18]"
		role="dialog"
		aria-modal="true"
		aria-labelledby="mobile-nav-drawer-title"
		inert
	>
		<div class="flex min-h-0 flex-1 flex-col">
			<div
				class="flex shrink-0 items-center justify-between gap-3 border-b border-red-900/45 px-4 pb-4 pt-3 sm:px-5"
			>
				<div class="min-w-0 flex-1">
					<p id="mobile-nav-drawer-title" class="sr-only">{restaurant.name}</p>
					<img
						src="/logo-niki-512.png"
						alt=""
						aria-hidden="true"
						width="512"
						height="249"
						class="h-8 w-auto max-w-[10.5rem] drop-shadow-[0_2px_10px_rgba(255,59,32,0.24)]"
						loading="eager"
						decoding="async"
					/>
				</div>
				<button
					type="button"
					id="mobile-nav-close-btn"
					class="inline-flex min-h-[44px] min-w-[44px] shrink-0 items-center justify-center rounded-xl border border-red-800/55 bg-zinc-900/92 text-yellow-300 shadow-inner shadow-black/30 transition hover:border-red-600/70 hover:bg-red-950/35 hover:text-yellow-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400"
					aria-label="Mbyll menynë"
				>
					<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</div>

			<nav
				class="flex flex-col gap-1 overflow-y-auto px-4 pb-[max(1rem,env(safe-area-inset-bottom))] pt-5 sm:px-5"
				aria-label="Menyja"
			>
				<a
					href={menuHref}
					class="mobile-nav-drawer-link rounded-xl px-4 py-3.5 text-base font-medium text-zinc-100 transition hover:bg-red-500/[0.10] hover:text-yellow-200 focus-visible:bg-red-500/[0.10] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400 active:bg-red-500/[0.14]"
					data-mobile-drawer-link
				>
					{menuLabel}
				</a>
			</nav>
		</div>
	</aside>
</div>

<script>
	import { initMobileNavDrawer } from '../../scripts/mobile-nav-drawer-client';
	initMobileNavDrawer();
</script>
