---
import { mainNavItems } from '../../data/navigation';
import { restaurant } from '../../data/restaurant';

const menuHref = mainNavItems[0]?.href ?? '#menu';
const menuLabel = mainNavItems[0]?.label ?? 'Menyja';
---

<div
	id="mobile-nav-drawer-root"
	class="mobile-nav-drawer-root fixed inset-0 z-[200] max-w-full overflow-x-clip md:hidden"
	aria-hidden="true"
>
	<button
		type="button"
		class="mobile-nav-drawer-backdrop absolute inset-0 z-0 bg-zinc-950/70 backdrop-blur-md supports-[backdrop-filter]:bg-zinc-950/50 sm:bg-zinc-950/65 sm:backdrop-blur-lg"
		data-mobile-drawer-backdrop
		aria-label="Mbyll menynë"
	>
	</button>

	<aside
		id="mobile-nav-drawer"
		class="mobile-nav-drawer-panel absolute right-0 top-0 z-10 flex h-full max-h-[100dvh] min-w-0 w-[min(22rem,calc(100%-1rem))] max-w-[min(22rem,calc(100%-1rem))] flex-col border-l border-amber-900/45 bg-zinc-950 pt-[env(safe-area-inset-top)] shadow-2xl shadow-black/70 ring-1 ring-white/[0.06]"
		role="dialog"
		aria-modal="true"
		aria-labelledby="mobile-nav-drawer-title"
		inert
	>
		<div class="flex min-h-0 flex-1 flex-col">
			<div
				class="flex shrink-0 items-center justify-between gap-3 border-b border-amber-900/35 px-4 pb-4 pt-3 sm:px-5"
			>
				<p
					id="mobile-nav-drawer-title"
					class="font-display min-w-0 truncate text-base font-semibold tracking-tight text-amber-100/95"
				>
					{restaurant.name}
				</p>
				<button
					type="button"
					id="mobile-nav-close-btn"
					class="inline-flex min-h-[44px] min-w-[44px] shrink-0 items-center justify-center rounded-xl border border-amber-800/45 bg-zinc-900/90 text-amber-200 shadow-inner shadow-black/30 transition hover:border-amber-600/55 hover:bg-amber-950/35 hover:text-amber-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-400"
					aria-label="Mbyll menynë"
				>
					<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</div>

			<nav
				class="flex flex-col gap-1 overflow-y-auto px-4 pb-[max(1rem,env(safe-area-inset-bottom))] pt-5 sm:px-5"
				aria-label="Menyja"
			>
				<a
					href={menuHref}
					class="mobile-nav-drawer-link rounded-xl px-4 py-3.5 text-base font-medium text-zinc-100 transition hover:bg-white/[0.06] hover:text-amber-200 focus-visible:bg-white/[0.06] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-400 active:bg-white/[0.08]"
					data-mobile-drawer-link
				>
					{menuLabel}
				</a>
			</nav>
		</div>
	</aside>
</div>

<script>
	import { initMobileNavDrawer } from '../../scripts/mobile-nav-drawer-client';
	initMobileNavDrawer();
</script>
