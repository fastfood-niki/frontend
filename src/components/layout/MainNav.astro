---
import { mainNavItems } from '../../data/navigation';

const menuHref = mainNavItems[0]?.href ?? '#menu';
const menuLabel = mainNavItems[0]?.label ?? 'Menyja';
---

<nav class="flex items-center justify-end md:flex-1 md:justify-center" aria-label="Primary navigation">
	<a
		href={menuHref}
		class="hidden min-h-[44px] items-center rounded-lg px-4 py-2 text-sm font-medium text-zinc-300 transition hover:bg-white/5 hover:text-amber-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-400 md:inline-flex"
	>
		{menuLabel}
	</a>

	<button
		type="button"
		id="mobile-nav-open-btn"
		class="mobile-nav-burger inline-flex min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center rounded-xl border border-amber-900/40 bg-zinc-900/80 text-amber-200 shadow-sm ring-1 ring-white/[0.04] transition hover:border-amber-600/45 hover:bg-amber-950/30 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-400 md:hidden"
		aria-expanded="false"
		aria-controls="mobile-nav-drawer"
	>
		<span class="sr-only">Open navigation menu</span>
		<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
			<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
		</svg>
	</button>
</nav>
