---
import { Bike } from 'lucide';
import { Image } from 'astro:assets';
import Container from '../common/Container.astro';
import MainNav from './MainNav.astro';
import { restaurant } from '../../data/restaurant';
import { lucideIconToSvg } from '../../lib/lucide-ssr';

const deliveryIconHero = lucideIconToSvg(Bike, {
	size: 24,
	class: 'h-6 w-6 text-yellow-300',
});
---

<header class="relative">
	<div
		class="relative z-10 w-full border-b border-red-950/50 bg-black/95 shadow-sm shadow-black/35"
	>
		<Container class="flex h-14 items-center gap-3 sm:h-16 sm:gap-6">
			<a
				href="/"
				aria-label={restaurant.name}
				class="group max-w-[48%] shrink-0 focus-visible:rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400 sm:max-w-none"
			>
				<Image
					src="/logo-niki-512.png"
					alt=""
					aria-hidden="true"
					width="512"
					height="249"
					class="h-9 w-auto drop-shadow-[0_2px_10px_rgba(255,59,32,0.24)] transition-opacity duration-200 group-hover:opacity-90 sm:h-10"
					loading="eager"
					decoding="async"
				/>
			</a>
			<div class="flex min-w-0 flex-1 items-center justify-end md:justify-center">
				<MainNav />
			</div>
			<a
				href={restaurant.phoneHref}
				aria-label={`Call ${restaurant.phone}`}
				class="inline-flex h-10 shrink-0 items-center justify-center rounded-full border border-red-700/35 bg-red-600/10 px-3 text-xs font-semibold text-yellow-300 transition hover:border-red-500/60 hover:bg-red-500/20 hover:text-yellow-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400 sm:px-4 sm:text-sm"
			>
				<span class="hidden sm:inline">{restaurant.phone}</span>
				<svg
					class="h-5 w-5 sm:hidden"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
					></path>
				</svg>
			</a>
		</Container>
	</div>

	<div
		class="relative overflow-hidden border-b border-red-950/45 bg-gradient-to-b from-black via-zinc-950 to-zinc-900 pb-12 pt-6 sm:pb-16 sm:pt-8"
	>
		<div class="pointer-events-none absolute inset-0 opacity-[0.35]" aria-hidden="true">
			<div
			class="absolute inset-0 bg-[linear-gradient(to_right,rgba(220,38,38,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(220,38,38,0.08)_1px,transparent_1px)] bg-[size:48px_48px]"
			>
			</div>
			<div
			class="absolute inset-0 bg-[radial-gradient(ellipse_75%_55%_at_50%_-15%,rgba(255,59,32,0.2),transparent_58%)]"
			>
			</div>
		</div>
		<div
			class="pointer-events-none absolute -left-24 top-1/2 h-64 w-64 -translate-y-1/2 rounded-full bg-red-500/15 blur-3xl sm:left-10"
			aria-hidden="true"
		>
		</div>
		<div
			class="pointer-events-none absolute -right-24 top-1/4 h-56 w-56 rounded-full bg-yellow-500/10 blur-3xl sm:right-16"
			aria-hidden="true"
		>
		</div>

		<Container class="relative z-20 mx-auto max-w-6xl px-4 pt-14 text-center sm:px-6 sm:pt-16 lg:px-8">
			<h1 class="sr-only">{restaurant.name}</h1>
			<Image
				src="/logo-niki-transparent.png"
				alt=""
				aria-hidden="true"
				width="1729"
				height="841"
				class="mx-auto w-full max-w-[min(34rem,76vw)] sm:max-w-[min(36rem,72vw)] lg:max-w-[31rem] drop-shadow-[0_8px_24px_rgba(0,0,0,0.45)]"
				loading="eager"
				decoding="async"
			/>
			<p
				class="mx-auto mt-5 max-w-xl text-base font-medium leading-relaxed text-yellow-100/85 sm:text-lg sm:leading-relaxed"
			>
				<span class="font-display italic text-yellow-100/90">{restaurant.tagline}</span>
			</p>

			<div
				class="relative -mx-4 mt-6 w-[calc(100%+2rem)] max-w-[calc(100%+2rem)] sm:-mx-6 sm:mt-8 sm:w-[calc(100%+3rem)] sm:max-w-[calc(100%+3rem)] lg:-mx-8 lg:w-[calc(100%+4rem)] lg:max-w-[calc(100%+4rem)]"
				aria-hidden="true"
			>
				<div class="hero-delivery-stage relative z-[8] h-[4.25rem] sm:h-[4.5rem]">
					<div class="hero-delivery-animate-bike">
						<div class="hero-delivery-animate-smoke">
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
						</div>
						<div class="hero-delivery-bike-disk">
							<span class="hero-delivery-animate-bike-inner" set:html={deliveryIconHero} />
						</div>
					</div>
					<div class="hero-delivery-animate-text">{restaurant.deliveryNote}</div>
				</div>
			</div>
		</Container>
	</div>
</header>
