---
import { Bike } from 'lucide';
import Container from '../common/Container.astro';
import MainNav from './MainNav.astro';
import { restaurant } from '../../data/restaurant';
import { lucideIconToSvg } from '../../lib/lucide-ssr';

const deliveryIconHero = lucideIconToSvg(Bike, {
	size: 24,
	class: 'h-6 w-6 text-amber-300',
});
---

<header class="relative">
	<div
		class="relative z-10 w-full border-b border-amber-950/40 bg-zinc-950 shadow-sm shadow-black/20"
	>
		<Container class="flex h-14 items-center gap-3 sm:h-16 sm:gap-6">
			<a
				href="/"
				class="group max-w-[42%] shrink-0 truncate font-display text-base font-semibold tracking-tight text-amber-100/95 transition-colors hover:text-amber-50 focus-visible:rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-400 sm:max-w-none sm:text-lg"
			>
				<span
					class="bg-gradient-to-r from-amber-200 via-amber-100 to-amber-300 bg-clip-text text-transparent group-hover:from-amber-100 group-hover:via-white group-hover:to-amber-200"
				>
					{restaurant.name}
				</span>
			</a>
			<div class="flex min-w-0 flex-1 items-center justify-end md:justify-center">
				<MainNav />
			</div>
			<a
				href={restaurant.phoneHref}
				aria-label={`Call ${restaurant.phone}`}
				class="inline-flex h-10 shrink-0 items-center justify-center rounded-full border border-amber-600/25 bg-amber-500/10 px-3 text-xs font-semibold text-amber-300 transition hover:border-amber-500/45 hover:bg-amber-500/15 hover:text-amber-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-400 sm:px-4 sm:text-sm"
			>
				<span class="hidden sm:inline">{restaurant.phone}</span>
				<svg
					class="h-5 w-5 sm:hidden"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
					></path>
				</svg>
			</a>
		</Container>
	</div>

	<div
		class="relative overflow-hidden border-b border-amber-950/30 bg-gradient-to-b from-zinc-950 via-zinc-950 to-zinc-900/80 pb-12 pt-6 sm:pb-16 sm:pt-8"
	>
		<div class="pointer-events-none absolute inset-0 opacity-[0.35]" aria-hidden="true">
			<div
				class="absolute inset-0 bg-[linear-gradient(to_right,rgba(245,158,11,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(245,158,11,0.03)_1px,transparent_1px)] bg-[size:48px_48px]"
			>
			</div>
			<div
				class="absolute inset-0 bg-[radial-gradient(ellipse_75%_55%_at_50%_-15%,rgba(251,191,36,0.18),transparent_55%)]"
			>
			</div>
		</div>
		<div
			class="pointer-events-none absolute -left-24 top-1/2 h-64 w-64 -translate-y-1/2 rounded-full bg-amber-500/10 blur-3xl sm:left-10"
			aria-hidden="true"
		>
		</div>
		<div
			class="pointer-events-none absolute -right-24 top-1/4 h-56 w-56 rounded-full bg-amber-600/10 blur-3xl sm:right-16"
			aria-hidden="true"
		>
		</div>

		<Container class="relative z-20 mx-auto max-w-6xl px-4 pt-14 text-center sm:px-6 sm:pt-16 lg:px-8">
			<h1
				class="font-display text-[clamp(2rem,6vw,3.75rem)] font-semibold leading-[1.08] tracking-tight text-white"
			>
				<span
					class="bg-gradient-to-br from-amber-50 via-amber-200 to-amber-500 bg-clip-text text-transparent drop-shadow-sm"
				>
					{restaurant.name}
				</span>
			</h1>
			<p
				class="mx-auto mt-5 max-w-xl text-base font-medium leading-relaxed text-amber-200/85 sm:text-lg sm:leading-relaxed"
			>
				<span class="font-display italic text-amber-100/90">{restaurant.tagline}</span>
			</p>

			<div
				class="relative -mx-4 mt-6 w-[calc(100%+2rem)] max-w-[calc(100%+2rem)] sm:-mx-6 sm:mt-8 sm:w-[calc(100%+3rem)] sm:max-w-[calc(100%+3rem)] lg:-mx-8 lg:w-[calc(100%+4rem)] lg:max-w-[calc(100%+4rem)]"
				aria-hidden="true"
			>
				<div class="hero-delivery-stage relative z-[8] h-[4.25rem] sm:h-[4.5rem]">
					<div class="hero-delivery-animate-bike">
						<div class="hero-delivery-animate-smoke">
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
							<span class="hero-delivery-animate-smoke-dot"></span>
						</div>
						<div class="hero-delivery-bike-disk">
							<span class="hero-delivery-animate-bike-inner" set:html={deliveryIconHero} />
						</div>
					</div>
					<div class="hero-delivery-animate-text">{restaurant.deliveryNote}</div>
				</div>
			</div>
		</Container>
	</div>
</header>
