---
import { categoryLucideIcons, type CategoryIconId } from '../../data/categoryIcons';
import { lucideIconToSvg } from '../../lib/lucide-ssr';

interface Props {
	categoryId: string;
	variant?: 'tab' | 'section';
}

const { categoryId, variant = 'tab' } = Astro.props;

const id = categoryId as CategoryIconId;
const nodes = id in categoryLucideIcons ? categoryLucideIcons[id] : null;

const size = variant === 'section' ? 22 : 18;
const svgClass =
	variant === 'section'
		? 'h-[22px] w-[22px] shrink-0 text-yellow-300'
		: 'h-[18px] w-[18px] shrink-0 text-yellow-300';

const svg = nodes ? lucideIconToSvg(nodes, { size, class: svgClass }) : '';

const outerTab = 'inline-flex items-center justify-center';
const outerSection =
	'flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-red-600/14 ring-1 ring-red-500/35 shadow-[0_0_16px_-4px_rgba(255,59,32,0.32)]';
---

{
	svg && (
		<span
			class:list={[variant === 'section' ? outerSection : outerTab]}
			aria-hidden="true"
			set:html={svg}
		/>
	)
}
