---
import { Star } from 'lucide';
import type { MenuItem as MenuItemType } from '../../data/menu';
import { lucideIconToSvg } from '../../lib/lucide-ssr';

interface Props {
	item: MenuItemType;
}

const { item } = Astro.props;

const showStar = item.badge === 'Popular';
const starSvg = showStar
	? lucideIconToSvg(Star, {
			size: 16,
			class: 'text-yellow-300 drop-shadow-[0_0_8px_rgba(253,224,71,0.35)]',
		})
	: '';
---

<div class="rounded-xl px-0.5 py-2.5 transition-colors hover:bg-red-500/[0.06] sm:px-1 md:py-3">
	<div class="flex items-end gap-2 sm:gap-3">
		<div class="min-w-0 flex-1">
			<div class="flex flex-wrap items-center gap-x-2 gap-y-1">
				<span class="text-[15px] font-medium leading-snug tracking-tight text-zinc-100 sm:text-base">
					{item.name}
				</span>
				{
					showStar && (
						<span class="inline-flex shrink-0 translate-y-px items-center" aria-label="Specialty" title="Specialty">
							<span aria-hidden="true" set:html={starSvg} />
						</span>
					)
				}
				{
					item.badge && !showStar && (
						<span class="inline-flex shrink-0 rounded-md bg-red-500/20 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-yellow-200 ring-1 ring-red-400/35">
							{item.badge}
						</span>
					)
				}
			</div>
			{
				item.description && (
					<p class="mt-1 text-xs leading-relaxed text-zinc-400">{item.description}</p>
				)
			}
		</div>
		<span
			class="mb-1.5 hidden min-h-[1px] flex-1 border-b border-dotted border-red-600/45 sm:block"
			aria-hidden="true"
		></span>
		<span class="shrink-0 text-[15px] font-semibold tabular-nums tracking-tight text-yellow-300 sm:text-base">
			{item.price}
		</span>
	</div>
</div>
