---
import type { MenuCategory } from '../../data/menu';
import Container from '../common/Container.astro';
import CategoryLucideIcon from '../icons/CategoryLucideIcon.astro';

interface Props {
	categories: MenuCategory[];
}

const { categories } = Astro.props;
---

<nav
	class="sticky top-0 z-[90] w-full min-w-0 max-w-full overflow-x-clip border-b border-amber-950/50 bg-zinc-950 shadow-[0_12px_40px_-8px_rgba(0,0,0,0.9)]"
	aria-label="Kategoritë e menusë"
>
	<Container
		class="flex min-w-0 max-w-full justify-start overflow-x-auto overflow-y-hidden overscroll-x-contain scroll-smooth px-4 py-3 snap-x snap-mandatory sm:px-6 sm:py-3.5 md:justify-center lg:px-8 [scrollbar-width:thin] [scrollbar-color:rgba(180,83,9,0.55)_#18181b] [&::-webkit-scrollbar]:h-1.5 [&::-webkit-scrollbar-thumb]:rounded-full [&::-webkit-scrollbar-thumb]:bg-amber-700/55 [&::-webkit-scrollbar-track]:rounded-full [&::-webkit-scrollbar-track]:bg-zinc-900"
	>
		<ul class="flex w-max flex-nowrap items-stretch justify-start gap-2 sm:gap-2.5" role="list">
			{
				categories.map((cat) => (
					<li class="flex shrink-0 snap-start py-0.5">
						<a
							href={`#${cat.id}`}
							data-category-tab
							data-category-id={cat.id}
							class="category-tab inline-flex min-h-[44px] items-center justify-center gap-2 rounded-xl border border-amber-900/35 bg-gradient-to-b from-zinc-900 to-zinc-950 px-4 py-2 text-sm font-medium text-zinc-100 shadow-sm ring-1 ring-white/[0.04] transition-[border-color,box-shadow,background-color,color,transform] duration-200 hover:border-amber-600/45 hover:from-amber-950 hover:to-zinc-950 hover:text-amber-50 hover:shadow-md hover:shadow-amber-950/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-400 active:scale-[0.98]"
						>
							<CategoryLucideIcon categoryId={cat.id} variant="tab" />
							<span class="whitespace-nowrap">{cat.title}</span>
						</a>
					</li>
				))
			}
		</ul>
	</Container>
</nav>

<script>
	import { setupCategoryHighlight } from '../../scripts/category-highlight-client';
	setupCategoryHighlight();
</script>
