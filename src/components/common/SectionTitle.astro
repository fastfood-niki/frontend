---
import CategoryLucideIcon from '../icons/CategoryLucideIcon.astro';

interface Props {
	title: string;
	categoryId?: string;
	as?: 'h2' | 'h3';
	id?: string;
	class?: string;
}

const { title, categoryId, as: Tag = 'h2', id, class: className }: Props = Astro.props;
---

<Tag
	id={id}
	class:list={[
		'font-display mb-5 flex items-center gap-3 border-b border-amber-500/15 pb-3 text-xl font-semibold tracking-tight text-amber-50 sm:text-2xl',
		className,
	]}
>
	{categoryId && <CategoryLucideIcon categoryId={categoryId} variant="section" />}
	<span>{title}</span>
</Tag>
